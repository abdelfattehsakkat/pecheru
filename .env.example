# ─── FishCall — configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Public URL used in email links and push notifications
PUBLIC_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Strong random secret for JWT signing
JWT_SECRET=change-me-to-a-long-random-string

# Admin password — plain text for dev convenience.
# In production, set ADMIN_PASSWORD_HASH instead (see services/auth.js).
ADMIN_PASSWORD=fishcall2024

# ── Database ─────────────────────────────────────────────────────────────────
# Directory where fishcall.db will be stored
DB_DIR=./data

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOADS_DIR=./public/uploads

# ── SMTP (Nodemailer) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="FishCall 🎣 <your-email@gmail.com>"

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@fishcall.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
